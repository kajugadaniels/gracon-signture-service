# signature .env.example - managed by Milestone 10 secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3002
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
DATABASE_URL=

# Shared user JWT
# Must match api/auth JWT_SECRET.
JWT_SECRET=

# Shared identity encryption
# Must match api/auth ENCRYPTION_SECRET.
ENCRYPTION_SECRET=

# Signature private-key encryption
# Generate SIGNATURE_ENCRYPTION_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SIGNATURE_ENCRYPTION_SECRET=

# Foreign identity service
# Generate FOREIGN_IDENTITY_SERVICE_PASSWORD with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
FOREIGN_IDENTITY_SERVICE_URL=http://localhost:3006/api/v1
FOREIGN_IDENTITY_SERVICE_USERNAME=service.foreign-identity@yourplatform.com
FOREIGN_IDENTITY_SERVICE_PASSWORD=
FOREIGN_IDENTITY_CACHE_TTL_MS=300000

# Internal admin review auth
# Generate SIGNATURE_SERVICE_PASSWORD with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SIGNATURE_SERVICE_USERNAME=service.signature-admin@yourplatform.com
SIGNATURE_SERVICE_PASSWORD=

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Frontend and CORS
FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=http://localhost:4001,http://localhost:4002
