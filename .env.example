# ─── App ─────────────────────────────────────────────────────────────────────
APP_PORT=3002
APP_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Same Neon Postgres as api/auth/ — never run prisma migrate here
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT (shared with api/auth/ — validates user tokens issued there) ─────────
# MUST be identical to JWT_SECRET in api/auth/ — this service validates,
# not issues, so it needs the same signing secret
JWT_SECRET=same_secret_as_auth_service_here

# ─── Shared Identity Encryption (matches api/auth/) ───────────────────────────
# Required to decrypt NID / FIN values stored in citizen_identities
ENCRYPTION_SECRET=same_encryption_secret_as_auth_service_here

# ─── Signature Encryption ─────────────────────────────────────────────────────
# Master secret for per-user private key derivation
# NEVER share this with any other service — unique to api/signature/
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SIGNATURE_ENCRYPTION_SECRET=generate_a_unique_64_char_secret_for_signature_service

# ─── Foreign Identity Service (for FIN-backed certificate issuance) ───────────
FOREIGN_IDENTITY_SERVICE_URL=http://localhost:3006/api/v1
# Use the same dedicated service credentials configured in api/auth/ so
# api/signature and api/auth authenticate to api/foreign-identity consistently.
FOREIGN_IDENTITY_SERVICE_USERNAME=service.foreign-identity@yourplatform.com
FOREIGN_IDENTITY_SERVICE_PASSWORD=your_foreign_identity_service_password
FOREIGN_IDENTITY_CACHE_TTL_MS=300000

# ─── AWS S3 (same bucket as api/auth/) ───────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_s3_bucket_name

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Optional additional allowed origins, comma-separated.
# Add the admin app and the documents app so they can call the signature API.
FRONTEND_URLS=http://localhost:4001,http://localhost:4002
